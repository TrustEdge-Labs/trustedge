    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.4.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0"
  },
  "type": "module",
  "overrides": {
    "cookie": "^0.7.0"
