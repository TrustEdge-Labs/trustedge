# TrustEdge Platform — Environment Configuration
#
# Copy this file to deploy/.env before running docker-compose.
# Dev defaults are provided — change credentials for non-local deployments.
#
# Usage:
#   cp deploy/.env.example deploy/.env
#   docker compose -f deploy/docker-compose.yml up --build

# ── Credentials ─────────────────────────────────────────────────────────────
# IMPORTANT: Change these for any non-local deployment.

POSTGRES_PASSWORD=trustedge_dev
DATABASE_URL=postgres://trustedge:trustedge_dev@postgres:5432/trustedge

# ── Server ──────────────────────────────────────────────────────────────────

# Port the HTTP server listens on. Must be a valid integer; invalid values fail fast.
# Default: 3001
# PORT=3001

# How long verification receipts remain valid (seconds).
# Default: 3600 (1 hour)
# RECEIPT_TTL_SECS=3600

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins for the platform API.
# Set to the URL(s) your dashboard or client app is served from.
# Default: (none — CORS disabled if unset)
# CORS_ORIGINS=http://localhost:8080,https://dashboard.example.com

# ── JWT / Authentication ─────────────────────────────────────────────────────

# Expected JWT audience claim. Must match the 'aud' field in tokens you issue.
# Default: trustedge-platform
# JWT_AUDIENCE=trustedge-platform

# Path to the JWKS Ed25519 signing key file (inside the container).
# Default: /jwks/signing.key (generated at startup if not present)
# JWKS_KEY_PATH=/jwks/signing.key

# ── Dashboard ────────────────────────────────────────────────────────────────

# Platform API URL that the dashboard fetches from in the browser.
# This is baked into the static JS at Docker build time.
# Default: http://localhost:3001
# VITE_API_BASE=http://localhost:3001

# -- TLS / HTTPS (nginx dashboard) ───────────────────────────────────────────

# Enable HTTPS termination in the nginx container by setting both paths.
# Paths are inside the container (use a volume mount to provide the files).
# Leave unset (or empty) for HTTP-only operation (local dev default).
#
# SSL_CERT_PATH=/certs/server.crt
# SSL_KEY_PATH=/certs/server.key
