# MPL-2.0: https://mozilla.org/MPL/2.0/
#
# Verify-only mode: no DATABASE_URL required.
# These defaults are already set in app.yaml envs; override here if needed.

# ── Server ──────────────────────────────────────────────────────────────────

# Port the HTTP server listens on.
# Default: 3001
# PORT=3001

# How long verification receipts remain valid (seconds).
# Default: 3600 (1 hour)
# RECEIPT_TTL_SECS=3600

# ── Rate Limiting ────────────────────────────────────────────────────────────

# Requests per second per IP on verify endpoints.
# Default: 10
# RATE_LIMIT_RPS=10

# ── Logging ──────────────────────────────────────────────────────────────────

# Log level: error | warn | info | debug | trace
# Default: info
# RUST_LOG=info

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated allowed CORS origins. Leave unset to allow all origins
# (acceptable for public verify endpoint at demo stage).
# CORS_ORIGINS=https://yourapp.example.com

# ── Not needed in verify-only mode ──────────────────────────────────────────
# DATABASE_URL — not required (no postgres feature compiled in)
# JWKS_KEY_PATH — auto-generated at /tmp/trustedge_signing_key.json on startup
